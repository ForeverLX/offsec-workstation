{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 365,
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(sudo rm *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(sudo wg-quick *)",
      "Bash(sudo nixos-rebuild *)",
      "Bash(sudo systemctl * wg*)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push --force *)",
      "Read(**/.ssh/*)",
      "Read(**/.gnupg/*)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.env*)",
      "Edit(**/.ssh/*)",
      "Edit(**/.gnupg/*)",
      "Edit(**/wg0.conf)",
      "Edit(**/configuration.nix)"
    ]
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
        { "type": "command", "command": "~/.claude/hooks/pre-tool/block-network-execution.sh" },
        { "type": "command", "command": "~/.claude/hooks/pre-tool/block-infra-commands.sh" },
        { "type": "command", "command": "~/.claude/hooks/pre-tool/block-credential-access.sh" },
        { "type": "command", "command": "~/.claude/hooks/pre-tool/block-git-destructive.sh" },
        { "type": "command", "command": "~/.claude/hooks/pre-tool/block-destructive.sh" }
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec node \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "audit-context-building@trailofbits": true,
    "differential-review@trailofbits": true,
    "semgrep-rule-creator@trailofbits": true,
    "sharp-edges@trailofbits": true,
    "static-analysis@trailofbits": true,
    "variant-analysis@trailofbits": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "alwaysThinkingEnabled": true
}
