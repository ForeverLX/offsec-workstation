{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "small_model": "opencode-go/glm-5.1",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16000
  },
  "provider": {
    "opencode-go": {
      "npm": "@opencode/provider-go",
      "name": "OpenCode Go",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}",
        "baseURL": "https://opencode.ai/zen/go/v1"
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "instructions": [
    "Operator workstation config",
    "Dotfiles, Niri, Ghostty, container profiles",
    "Avoid deepseek-v4-pro due to reasoning_content bug"
  ]
}