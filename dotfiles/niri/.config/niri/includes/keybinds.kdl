// Keybindings - NightForge Operator Workstation
// Quickshell + Rofi + SwayOSD (replaces DMS keybinds)
// Mod = Super (Windows key)

binds {
    // ========== HELP ==========
    Mod+Shift+Slash { show-hotkey-overlay; }
    Mod+Shift+C { spawn "sh" "-c" "echo controlcenter > /tmp/quickshell-toggle"; }
    Mod+Slash { spawn "sh" "-c" "~/.config/niri/scripts/keybind-cheatsheet.sh"; }

    // ========== APPLICATIONS ==========
    Mod+Return { spawn "ghostty"; }

    // Rofi launcher (replaces DMS spotlight)
    Mod+D { spawn "rofi" "-show" "drun" "-theme" "~/.config/rofi/matugen-theme.rasi"; }

    // Focus-or-spawn
    Mod+B { spawn "sh" "-c" "~/.config/niri/scripts/focus-or-spawn.sh --app-id brave-browser brave"; }
    Mod+F { spawn "ghostty" "-e" "yazi"; }

    // ========== QUICKSHELL CONTROLS ==========
    // Toggle Quickshell bar visibility (if supported)
    Mod+Shift+B { spawn "pkill" "-USR1" "quickshell"; }

    // ========== SWAYOSD OVERLAYS ==========
    // Volume controls (SwayOSD)
    XF86AudioRaiseVolume allow-when-locked=true { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute allow-when-locked=true { spawn "swayosd-client" "--output-volume" "toggle"; }
    XF86AudioMicMute allow-when-locked=true { spawn "swayosd-client" "--input-volume" "toggle"; }

    // Brightness controls (SwayOSD)
    XF86MonBrightnessUp allow-when-locked=true { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "swayosd-client" "--brightness" "lower"; }

    // Media keys
    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }

    // Music popup toggle (MPD)
    Mod+M { spawn "sh" "-c" "echo music > /tmp/quickshell-toggle"; }

    // ========== CLIPBOARD / NOTIFICATIONS ==========
    // Replace DMS clipboard with cliphist + rofi
    Mod+V { spawn "rofi" "-modi" "clipboard:cliphist" "-show" "clipboard" "-theme" "~/.config/rofi/matugen-theme.rasi"; }

    // Notification center (swaync)
    // Mod+Shift+N removed — mako does not provide a notification center UI

    // ========== POWER / LOCK ==========
    Mod+Alt+L { spawn "hyprlock"; }
    // Note: Idle lock is handled by hypridle, not a keybind
    Mod+Alt+Q { quit; }
    Mod+Shift+E { spawn "bash" "/home/ForeverLX/Github/nightforge/scripts/engagement-edit.sh"; }

    // ========== WINDOW MANAGEMENT ==========
    Mod+Q { close-window; }
    Mod+Space repeat=false hotkey-overlay-title="Toggle overview" { toggle-overview; }
    Mod+Shift+Space { toggle-window-floating; }
    Mod+Shift+X { maximize-column; }
    Mod+W { toggle-column-tabbed-display; }
    Mod+G { toggle-window-floating; }
    Mod+C { center-column; }
    Mod+Alt+C hotkey-overlay-title="Center Window" { center-window; }

    // ========== SMART NAVIGATION (DT-Inspired) ==========
    // Horizontal: Navigate columns
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }

    // Vertical: Smart navigation (focus window OR switch workspace)
    Mod+J { focus-window-or-workspace-down; }
    Mod+K { focus-window-or-workspace-up; }

    // Workspace cycling
    Mod+U { focus-workspace-down; }
    Mod+I { focus-workspace-up; }

    // ========== SMART WINDOW MOVEMENT ==========
    // Move within workspace
    Mod+Shift+H { move-column-left; }
    Mod+Shift+L { move-column-right; }

    // Smart vertical movement (move window OR to workspace)
    Mod+Shift+J { move-window-down-or-to-workspace-down; }
    Mod+Shift+K { move-window-up-or-to-workspace-up; }

    // ========== MULTI-MONITOR ==========
    Mod+Shift+Left { move-column-to-monitor-left; }
    Mod+Shift+Right { move-column-to-monitor-right; }
    Mod+Alt+Left { focus-monitor-left; }
    Mod+Alt+Right { focus-monitor-right; }

    // ========== COLUMN MANAGEMENT ==========
    Mod+BracketLeft { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Period { expel-window-from-column; }

    // ========== OVERVIEW & WORKSPACES ==========
    Mod+Tab { focus-workspace-previous; }

    Mod+1 { focus-workspace "1"; }
    Mod+2 { focus-workspace "2"; }
    Mod+3 { focus-workspace "3"; }
    Mod+4 { focus-workspace "4"; }
    Mod+5 { focus-workspace "5"; }

    Mod+Shift+1 { move-column-to-workspace "1"; }
    Mod+Shift+2 { move-column-to-workspace "2"; }
    Mod+Shift+3 { move-column-to-workspace "3"; }
    Mod+Shift+4 { move-column-to-workspace "4"; }
    Mod+Shift+5 { move-column-to-workspace "5"; }

    // ========== RESIZING ==========
    Mod+Ctrl+H { set-window-width "-10%"; }
    Mod+Ctrl+L { set-window-width "+10%"; }
    Mod+Ctrl+J { set-window-height "-10%"; }
    Mod+Ctrl+K { set-window-height "+10%"; }
    Mod+R { switch-preset-column-width; }

    // ========== SCREENSHOTS ==========
    Mod+S { spawn "sh" "-c" "~/.config/niri/scripts/screenshot.sh area-pip"; }
    Mod+Shift+S { spawn "sh" "-c" "~/.config/niri/scripts/screenshot.sh area-clipboard"; }
    Mod+Ctrl+S { spawn "sh" "-c" "~/.config/niri/scripts/screenshot.sh area-edit"; }
    Mod+Alt+S { spawn "sh" "-c" "~/.config/niri/scripts/screenshot.sh screen"; }
    Mod+Alt+Shift+S { spawn "sh" "-c" "~/.config/niri/scripts/screenshot.sh screen-clipboard"; }
    Mod+Alt+W { screenshot-window; }
    Mod+Shift+R { spawn "sh" "-c" "~/.config/niri/scripts/rename-last-screenshot.sh"; }

    // ========== OBSIDIAN (NightForge vaults) ==========
    Mod+Shift+D { spawn "obsidian" "obsidian://daily"; }
    Mod+Shift+O { spawn "obsidian" "obsidian://search"; }
    Mod+O { spawn "obsidian" "obsidian://open?vault=azrael-vault"; }



    // ========== SYSTEM ==========
    Mod+Escape { toggle-keyboard-shortcuts-inhibit; }
    Mod+Shift+P { spawn "bash" "/home/ForeverLX/Github/nightforge/scripts/toggle-performance-mode.sh"; }

    // ========== WALLPAPER ROTATION (replaces DMS auto-switch) ==========
    // Manual rotation trigger + systemd timer for 15-min auto-rotate
    Mod+Alt+R { spawn "bash" "-c" "~/.local/bin/wallpaper-rotate.sh --notify && ~/.local/bin/matugen-sync.sh $(cat ~/.cache/current_wallpaper)"; }

    // ========== NIGHTFORGE OPERATOR SHORTCUTS ==========
    // Quick VPN toggle (WireGuard mesh) - click the bar indicator or use a script
    Mod+Shift+W { spawn "sh" "-c" "echo wallpaper > /tmp/quickshell-toggle"; }

    // Engagement status check
    Mod+Shift+G { spawn "ghostty" "-e" "cat ~/.config/nightforge/engagement-context 2>/dev/null || echo 'No active engagement'"; }

    // Podman container status
    Mod+Shift+T { spawn "ghostty" "-e" "podman ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"; }

}
