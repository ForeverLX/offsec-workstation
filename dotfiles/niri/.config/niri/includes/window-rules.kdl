// Window Rules
// Per-application geometry, opacity, and placement

// ========== GLOBAL APPEARANCE ==========
// Note: dms/layout.kdl sets corner-radius 12 and will override this value
window-rule {
    geometry-corner-radius 8
    clip-to-geometry true
}

// ========== BROWSERS ==========
window-rule {
    match app-id=r#"brave-browser$"#
    opacity 0.92
    default-column-width { proportion 0.66667; }
}

window-rule {
    match app-id=r#"brave-browser$"# title="^Picture-in-Picture$"
    open-floating true
    opacity 0.95
}

window-rule {
    match app-id=r#"firefox$"#
    opacity 1.0
}

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
    opacity 0.95
}

// ========== TERMINALS (Ghostty) ==========
window-rule {
    match app-id=r#"^com\.mitchellh\.ghostty$"#
    opacity 0.65
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id=r#"^com\.mitchellh\.ghostty$"# title=r#"^tmux-picker$"#
    open-fullscreen true
    opacity 0.65
}

// ========== NOTES (Obsidian) ==========
window-rule {
    match app-id=r#"obsidian$"#
    opacity 0.90
    default-column-width { proportion 0.5; }
}

// ========== CLAUDE DESKTOP ==========
window-rule {
    match app-id=r#"^electron$"# title=r#"^Claude$"#
    opacity 0.65
    default-column-width { proportion 0.45; }
}

// ========== SYSTEM TOOLS ==========
window-rule {
    match app-id=r#"yazi$"#
    opacity 0.85
}

window-rule {
    match app-id=r#"thunar$"#
    opacity 0.85
}

window-rule {
    match app-id=r#"btop$"#
    opacity 0.80
}

window-rule {
    match app-id=r#"pavucontrol$"#
    open-floating true
    opacity 0.92
}

// ========== SECURITY ==========
window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    block-out-from "screen-capture"
    opacity 1.0
}
