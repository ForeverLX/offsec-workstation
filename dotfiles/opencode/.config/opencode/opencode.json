{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/mistralai/codestral-2508",
  "small_model": "openrouter/google/gemini-2.5-flash",
  "snapshot": true,
  "autoupdate": false,
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "mistralai/codestral-2508": { "name": "Codestral 2508 (Execution)" },
        "deepseek/deepseek-v3.2": { "name": "DeepSeek V3.2 (Reasoning)" },
        "nvidia/nemotron-3-super-120b-a12b:free": { "name": "Nemotron 3 Super Free (Agentic)" },
        "nvidia/nemotron-3-super-120b-a12b": { "name": "Nemotron 3 Super (Escalation)" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash (QA/CI)" },
        "qwen/qwen3-235b-a22b": { "name": "Qwen3 235B (Long-Context/Review)" },
        "anthropic/claude-opus-4.6": { "name": "Opus 4.6 (Hard Escalation)" }
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo rm *": "deny",
      "*": "ask"
    },
    "webfetch": "ask"
  }
}
