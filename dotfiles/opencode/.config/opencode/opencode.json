{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-zen/kimi-k2.6",
  "small_model": "opencode-zen/openkili/big-pickle",
  "snapshot": true,
  "autoupdate": false,
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "agentmemory": {
      "command": "npx",
      "args": ["-y", "@agentmemory/mcp"],
      "env": {
        "AGENTMEMORY_URL": "http://127.0.0.1:3111"
      }
    }
  },
  "provider": {
    "opencode-go": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenCode Go",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}",
        "baseURL": "https://api.opencode.go/v1"
      },
      "models": {
        "kimi-k2.6": { "name": "Kimi K2.6 (Reasoning)" },
        "GLM-5.1": { "name": "GLM-5.1 (Premium)" },
        "openkili/big-pickle": { "name": "Big Pickle (Free)" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "mistralai/devstral-2512": { "name": "Devstral 2 2512 (Execution)" },
        "deepseek/deepseek-v3.2": { "name": "DeepSeek V3.2 (Reasoning)" },
        "qwen/qwen3-coder-480b-a35b:free": { "name": "Qwen3 Coder 480B Free (Agentic)" },
        "nvidia/nemotron-3-super-120b-a12b:free": { "name": "Nemotron 3 Super Free (Fallback)" },
        "google/gemini-2.5-flash": { "name": "Gemini 2.5 Flash (QA/CI)" },
        "qwen/qwen3-235b-a22b-2507-instruct": { "name": "Qwen3 235B 2507 (Long-Context)" },
        "anthropic/claude-opus-4.7": { "name": "Opus 4.7 (Hard Escalation)" }
      }
    },
    "opencode-zen": {
      "npm": "@opencode/provider-zen",
      "name": "OpenCode Zen",
      "options": {
        "baseURL": "https://opencode.ai/zen/api/v1",
        "apiKey": "{env:OPENCODE_ZEN_API_KEY}"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo rm *": "deny",
      "*": "ask"
    },
    "webfetch": "ask"
  }
}
