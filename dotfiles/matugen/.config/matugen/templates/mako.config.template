# Mako notification daemon config - generated by matugen

# Output and positioning
anchor=top-right
margin=10,10

# Styling
background-color=#{{colors.surface.default.hex}}DD
text-color=#{{colors.on_surface.default.hex}}
border-size=2
border-radius=8
border-color=#{{colors.primary.default.hex}}
progress-color=#{{colors.primary.default.hex}}

# Font
font=MesloLGS NF 12

# Timeout
default-timeout=5

# Grouped notifications
group-by=summary
